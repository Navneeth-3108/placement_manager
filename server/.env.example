PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Option A (recommended for hosted Postgres/Neon):
DATABASE_URL=postgres://user:password@host:5432/placement_manager?sslmode=require

# Option B (local DB credentials):
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=placement_manager
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_SSL=false
DB_LOGGING=false
DB_SYNC=false
RBAC_ENABLED=false
RBAC_ADMIN_EMAILS=24z218@psgtech.ac.in
